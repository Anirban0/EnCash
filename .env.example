# Copy to .env and fill in real values. NEVER commit the real .env.

# --- Django ---
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Set to 0 only when TLS is terminated elsewhere (e.g. local docker over HTTP).
DJANGO_SECURE_SSL_REDIRECT=1

# Origin(s) of the frontend dashboard, comma-separated. No wildcards.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# --- Database (PostgreSQL) ---
POSTGRES_DB=encash
POSTGRES_USER=encash
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# In local backend dev, set USE_POSTGRES=1 to use Postgres instead of SQLite.
USE_POSTGRES=0
